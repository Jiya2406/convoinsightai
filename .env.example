# ─────────────────────────────────────────────────────────────
# ConvoInsight AI — Environment Variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string from Neon (Phase 3 setup guide).
# Neon gives you a "pooled" connection string — use it here.
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/convoinsight?sslmode=require"

# Auth.js (NextAuth v5) secret used to sign session JWTs.
# Generate one with:  npx auth secret     (or)   openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Google Gemini API key (free tier) — used by GeminiAdapter in Phase 6.
# Leave blank for now; the platform defaults to the Mock provider.
GEMINI_API_KEY=""

# Active AI provider for the platform. Options: mock | gemini
# (openai/claude/deepseek/llama/azure are scaffolded but not wired in the MVP.)
AI_PROVIDER="mock"

# Active evaluator. Options: mock | gemini
EVALUATOR="mock"
